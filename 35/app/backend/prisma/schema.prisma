// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tasks {
  id           String          @id
  name         String
  AssignedTask AssignedTasks[]
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  @@map("tasks")
}

model Members {
  id           String          @id
  name         String
  email        String          @unique
  status       MemberStatus
  AssignedTask AssignedTasks[]
  PairMember   PairMembers?
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  @@map("members")
}

enum MemberStatus {
  ACTIVE
  PAUSING
  INACTIVE
}

model AssignedTasks {
  id        String             @id
  taskId    String             @map("task_id")
  memberId  String             @map("member_id")
  status    AssignedTaskStatus
  task      Tasks              @relation(fields: [taskId], references: [id])
  member    Members            @relation(fields: [memberId], references: [id])
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")

  @@unique([taskId, memberId])
  @@map("assigned_tasks")
}

enum AssignedTaskStatus {
  UNDONE
  REVIEWING
  DONE
}

model Teams {
  id        String   @id
  name      Int
  pairs     Pairs[]
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("teams")
}

model Pairs {
  id          String        @id
  teamId      String        @map("team_id")
  name        String
  team        Teams         @relation(fields: [teamId], references: [id])
  pairMembers PairMembers[]
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@map("pairs")
}

model PairMembers {
  pairId    String   @map("pair_id")
  memberId  String   @map("member_id")
  pair      Pairs    @relation(fields: [pairId], references: [id])
  member    Members  @relation(fields: [memberId], references: [id])
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([memberId])
  @@map("pair_members")
}
